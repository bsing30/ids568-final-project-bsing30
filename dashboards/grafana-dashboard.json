{
  "uid": "ids568-final-support-intent-dashboard",
  "title": "Support Intent API — Production Monitoring",
  "tags": ["mlops", "ids568"],
  "schemaVersion": 39,
  "version": 3,
  "editable": true,
  "timezone": "browser",
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": { "list": [] },
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "P95 Prediction Latency (seconds)",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 3,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.3 }
            ]
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
          "expr": "histogram_quantile(0.95, sum(rate(prediction_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
          "expr": "0.300",
          "legendFormat": "SLA guardrail (300ms)"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Rolling Error Rate (gauge)",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0.035 },
              { "color": "red", "value": 0.05 }
            ]
          }
        }
      },
      "options": { "legend": { "displayMode": "hidden" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
          "expr": "prediction_error_rate",
          "legendFormat": "error_rate"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Throughput (RPS gauge)",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
          "expr": "prediction_throughput_rps",
          "legendFormat": "rps"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Integrity + Drift Indicators",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
      "fieldConfig": {
        "defaults": { "decimals": 3 },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "input_anomaly_rate" },
            "properties": [{ "id": "unit", "value": "percentunit" }]
          },
          {
            "matcher": { "id": "byName", "options": "feature_drift_score" },
            "properties": [{ "id": "thresholds", "value": {
              "mode": "absolute",
              "steps": [
                { "color": "green", "value": null },
                { "color": "orange", "value": 0.2 },
                { "color": "red", "value": 0.25 }
              ]
            }}]
          }
        ]
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
          "expr": "feature_drift_score",
          "legendFormat": "feature_drift_score"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
          "expr": "input_anomaly_rate",
          "legendFormat": "input_anomaly_rate"
        }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Error Rate SLA Check (worst-case window surrogate)",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.05 }
            ]
          },
          "mappings": [
            { "type": "special", "options": { "match": "null", "text": "n/a" }}
          ]
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
          "expr": "prediction_error_rate",
          "instant": true
        }
      ]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "P95 Latency SLA Check",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 3,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.3 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
          "expr": "histogram_quantile(0.95, sum(rate(prediction_latency_seconds_bucket[5m])) by (le))",
          "instant": true
        }
      ]
    },
    {
      "id": 7,
      "type": "text",
      "title": "Operational Notes",
      "gridPos": { "x": 0, "y": 22, "w": 24, "h": 5 },
      "options": {
        "content": "**How to reproduce locally:** Run `METRICS_SERVE_PORT=8002 python src/monitoring/simulate_traffic.py` while Prometheus scrapes `:8002/metrics`.\\n\\nAlert rules live at `dashboards/prometheus-rules.yml` (integrate via Prometheus alerting).\\n\\nInterpretation memo: `docs/dashboard-interpretation.md`.",
        "mode": "markdown"
      }
    }
  ]
}
